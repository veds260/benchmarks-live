# GitHub token for higher API rate limits (optional but recommended)
# Get one at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Secret to protect cron endpoints (optional)
CRON_SECRET=

# OpenRouter API key for AI-powered model recommendations (optional)
# Without this, recommendations use keyword-based fallback parsing
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=
